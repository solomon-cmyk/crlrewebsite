NEXT_PUBLIC_SITE_URL=https://crlre.com

# Formspree contact form (required for lead modal submissions)
# Example: https://formspree.io/f/xxxxxxxx
NEXT_PUBLIC_FORMSPREE_FORM_URL=https://formspree.io/f/xjgqdqqq

# Soro autopublish (optional)
# Create a long random secret and use the same value in Soro webhook settings.
SORO_WEBHOOK_SECRET=

# Vercel Blob (required for Soro autopublish + live listing admin on Vercel)
# Create a Blob store in Vercel → Storage, link it to this project.
# Prefer BLOB_STORE_ID (private store). BLOB_READ_WRITE_TOKEN is an alternate.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Listings admin (/crlre-manage) — never commit real credentials
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
